# /var/www/ojialanshori/shared/.env
# Copy ke /var/www/ojialanshori/shared/.env di VPS dan isi nilainya.
# File ini di-load oleh systemd unit (EnvironmentFile=) saat service start.

# === Database ===
NUXT_MYSQL_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DB_NAME

# === Session ===
# Generate dengan: openssl rand -hex 32
NUXT_SESSION_SECRET=

# === Brevo Email ===
NUXT_BREVO_API_KEY=

# === Cloudflare R2 (S3 API) ===
# Dari Cloudflare dashboard > R2 > Manage API Tokens
NUXT_R2_ACCESS_KEY_ID=
NUXT_R2_SECRET_ACCESS_KEY=
NUXT_R2_BUCKET=ojialanshori
# Format: https://<account_id>.r2.cloudflarestorage.com
NUXT_R2_ENDPOINT=

# === Public ===
NUXT_PUBLIC_SITE_URL=https://ojialanshori.com
NUXT_PUBLIC_DISQUS_SHORTNAME=
